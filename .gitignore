# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors and IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs and generated output
*.log
logs/
**/output/

# Environment and local configuration
.env
.env.*
!.env.example

# Go
bin/
*.test
*.out
coverage/
coverage.*
coverage.out
coverage.html

# Node, Vite and frontend tooling
node_modules/
frontend/node_modules/
dist/
frontend/dist/
dist-ssr/
.vite/
frontend/.vite/
storybook-static/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Wails build output
build/bin/

# Local databases and runtime data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal

# Temporary files
tmp/
temp/
*.tmp

# Harness local auxiliary run surfaces
.agents/plans/*
!.agents/plans/TEMPLATE.md
!.agents/plans/EXAMPLE-implementation.md
.agents/state/*
!.agents/state/TEMPLATE.md
.agents/runs/*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors and IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs and generated output
*.log
logs/
!internal/codex/logs/
internal/codex/logs/*
!internal/codex/logs/*.go
**/output/

# Environment and local configuration
.env
.env.*
!.env.example

# Go
bin/
*.test
*.out
coverage/
coverage.*
coverage.out
coverage.html

# Local generated/tooling artifacts. These paths are not product source and may
# remain after migration from the legacy desktop stack.
node_modules/
dist/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.task/
build/bin/

# Local databases and runtime data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal

# Temporary files
.cache/
tmp/
temp/
*.tmp

# Machine-local validation evidence
.artifacts/

# Cursor project rules are commit-safe; other Cursor files stay local by default.
.cursor/*
!.cursor/rules/
!.cursor/rules/*.mdc

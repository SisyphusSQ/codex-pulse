{
  "name": "codex-pulse-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "build:dev": "npm run typecheck && vite build --minify false --mode development",
    "build": "npm run typecheck && vite build --mode production",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/vue-query": "5.101.2",
    "@wailsio/runtime": "3.0.0-alpha.97",
    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "3.5.39",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}
